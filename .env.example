# VITA Gateway Configuration
#
# For full config, edit: ~/.vita/vita.json
# Env vars here override vita.json values.

# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Gateway (overrides vita.json -> gateway block)
GATEWAY_PORT=8765
# GATEWAY_HOST=127.0.0.1
# VITA_SCRIPTS_ROOT=/home/spario/vita/scripts

# Auth token (auto-generated if not set; overrides vita.json)
# VITA_GATEWAY_TOKEN=

# Auth password (for Tailscale Funnel mode)
# VITA_GATEWAY_PASSWORD=

# Discord (optional)
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_DM_USER_ID=
# Enable the Discord Message Content Intent for the bot in the developer portal.
# Set DISCORD_DM_USER_ID if outbound notifications should always DM your account.
# Add channel IDs to gateway/data/vitas/*.vita.json under "discordChannels" only if you also want server-channel replies.

# Ollama (for heartbeats)
OLLAMA_URL=http://localhost:11434

# Chroma vector memory (optional)
# Leave unset to use SQLite memory only.
# CHROMA_URL=http://localhost:8000

# Wake Word (local-wake)
WAKE_WORD_REF_DIR=src/wakeword/refs
WAKE_WORD_THRESHOLD=0.1
WAKE_WORD_DEBUG=False
WAKE_WORD_METHOD=embedding
WAKE_WORD_BUFFER_SIZE=2.0
WAKE_WORD_SLIDE_SIZE=0.25

# Morning Brief (optional overrides for the gateway script suite)
# MORNING_BRIEF_VAULT_PATH=~/vault
# MORNING_BRIEF_LOCAL_VAULT_MIRROR=
# MORNING_BRIEF_TIMEZONE=America/New_York
# MORNING_BRIEF_WEATHER_LABEL=
# MORNING_BRIEF_WEATHER_LATITUDE=
# MORNING_BRIEF_WEATHER_LONGITUDE=
# MORNING_BRIEF_BROWSER_COMMAND=xdg-open "{{url}}"
# MORNING_BRIEF_BROWSER_PLAY_COMMAND=
# MORNING_BRIEF_BROWSER_CLOSE_COMMAND=
# MORNING_BRIEF_BROWSER_START_DELAY=8
# MORNING_BRIEF_PLAYBACK_BUFFER=0
# MORNING_BRIEF_AUDIO_PLAYER=
# MORNING_BRIEF_TEXT_MODEL=
# MORNING_BRIEF_TTS_MODEL=gemini-2.5-flash-preview-tts
# MORNING_BRIEF_TTS_VOICE=Algieba
