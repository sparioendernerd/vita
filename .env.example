# VITA Gateway Configuration
#
# For full config, edit: ~/.vita/vita.json
# Env vars here override vita.json values.

# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Gateway (overrides vita.json -> gateway block)
GATEWAY_PORT=8765
# GATEWAY_HOST=127.0.0.1

# Auth token (auto-generated if not set; overrides vita.json)
# VITA_GATEWAY_TOKEN=

# Auth password (for Tailscale Funnel mode)
# VITA_GATEWAY_PASSWORD=

# Discord (optional)
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_DM_USER_ID=
# Enable the Discord Message Content Intent for the bot in the developer portal.
# Set DISCORD_DM_USER_ID if outbound notifications should always DM your account.
# Add channel IDs to gateway/data/vitas/*.vita.json under "discordChannels" only if you also want server-channel replies.

# Ollama (for heartbeats)
OLLAMA_URL=http://localhost:11434

# Chroma vector memory (optional)
# Leave unset to use SQLite memory only.
# CHROMA_URL=http://localhost:8000

# Wake Word (local-wake)
WAKE_WORD_REF_DIR=src/wakeword/refs
WAKE_WORD_THRESHOLD=0.1
WAKE_WORD_DEBUG=False
WAKE_WORD_METHOD=embedding
WAKE_WORD_BUFFER_SIZE=2.0
WAKE_WORD_SLIDE_SIZE=0.25
