{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProtocolMessage",
  "type": "object",
  "required": ["type", "timestamp", "payload"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "node:register",
        "node:heartbeat",
        "node:status",
        "session:start",
        "session:end",
        "session:config",
        "tool:request",
        "tool:response",
        "transcript:entry",
        "gateway:ping",
        "vita:updated",
        "gateway:command"
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": { "type": "object" }
  }
}
